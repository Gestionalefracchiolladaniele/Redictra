# Redictra — Esempio di file .env (per lo sviluppo LOCALE).
# Copia in `.env` e riempi i valori. NON committare `.env` (è in .gitignore).
# In produzione (GitHub Actions) questi valori vanno nei SECRET del repository,
# NON in un file. Ogni valore: vedi SETUP_TODO.md per come ottenerlo.

# --- Gemini (Google AI Studio → API key) ---
GEMINI_API_KEY=__TODO_GEMINI_API_KEY__

# --- Supabase ---
SUPABASE_URL=__TODO_SUPABASE_URL__
NEXT_PUBLIC_SUPABASE_ANON_KEY=__TODO_SUPABASE_SERVICE_ANON_KEY__
SUPABASE_SERVICE_ROLE_KEY=__TODO_SUPABASE_SERVICE_ROLE_KEY__

# --- Telegram ---
TELEGRAM_BOT_TOKEN=__TODO_TELEGRAM_BOT_TOKEN__
TELEGRAM_BOT_USERNAME=__TODO_TELEGRAM_BOT_USERNAME__

# --- Accesso a invito ---
ACCESS_CODE=

# --- Reddit (PRAW) — app "script" su https://www.reddit.com/prefs/apps ---
REDDIT_CLIENT_ID=__TODO_REDDIT_CLIENT_ID__
REDDIT_CLIENT_SECRET=__TODO_REDDIT_CLIENT_SECRET__
REDDIT_USER_AGENT=Redictra/1.0 (by u/your_reddit_user)
